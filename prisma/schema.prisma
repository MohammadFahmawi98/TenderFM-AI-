generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  FACILITY_MANAGEMENT
  CLEANING
  LANDSCAPING
  MEP_CONTRACTOR
  HVAC_CONTRACTOR
  SECURITY
  PEST_CONTROL
  GOVERNMENT_ENTITY
  PROPERTY_MANAGEMENT
}

enum TenderStatus {
  DRAFT
  UPLOADED
  PROCESSING
  ANALYZED
  QUALIFIED
  NO_GO
  IN_ESTIMATION
  IN_PROPOSAL
  SUBMITTED
  WON
  LOST
  ARCHIVED
}

enum FilePurpose {
  TENDER_DOCUMENT
  COMPANY_DOCUMENT
  GENERATED_EXPORT
  CERTIFICATE
  DRAWING
  BOQ
  ASSET_REGISTER
  ADDENDUM
}

enum ExtractionStatus {
  PENDING
  COMPLETED
  FAILED
  UNSUPPORTED
}

enum TenderFileCategory {
  RFP_MAIN_DOCUMENT
  BOQ
  TECHNICAL_SPECIFICATION
  CONTRACT_CONDITIONS
  DRAWINGS
  APPENDICES
  COMPLIANCE_DOCUMENTS
  PRICING_DOCUMENTS
  CLIENT_FORMS
  OTHER
}

enum ComplianceStatus {
  AVAILABLE
  MISSING
  PARTIAL
  NOT_APPLICABLE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  COMMERCIAL
  TECHNICAL
  FINANCIAL
  OPERATIONAL
  COMPLIANCE
  RESOURCE
}

enum Recommendation {
  GO
  GO_WITH_CONDITIONS
  NO_GO
  REVIEW_REQUIRED
}

enum GeneratedFileType {
  PDF
  DOCX
  XLSX
  PPTX
  ZIP
}

enum GeneratedDocumentKind {
  TECHNICAL_PROPOSAL
  COMMERCIAL_PROPOSAL
  COMPLIANCE_MATRIX
  MANPOWER_PLAN
  PPM_SCHEDULE
  SLA_MATRIX
  KPI_MATRIX
  RISK_REGISTER
  HSE_PLAN
  METHOD_STATEMENT
  EXECUTIVE_SUMMARY
  POWERPOINT_PRESENTATION
  EXCEL_COST_SHEET
  SUBMISSION_PACKAGE
}

enum ReviewStatus {
  DRAFT
  AI_GENERATED
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  FINAL
  REJECTED
}

enum WorkspaceTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  APPROVED
  BLOCKED
  COMPLETED
}

enum IntegrationProvider {
  GOOGLE_DRIVE
  MICROSOFT_365
  GMAIL
  OUTLOOK
  SLACK
  MICROSOFT_TEAMS
  CALENDAR
  SUPABASE
  OPENAI
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  NEEDS_ATTENTION
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  type         OrganizationType
  country      String?
  website      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  users        User[]
  tenders      Tender[]
  files        TenderFile[]
  suppliers    Supplier[]
  auditLogs    AuditLog[]
  subscription Subscription?

  @@index([name])
}

model User {
  id             String         @id @default(cuid())
  organizationId String
  email          String         @unique
  firstName      String
  lastName       String
  phone          String?
  title          String?
  passwordHash   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roles          UserRole[]
  tenders        Tender[]       @relation("TenderOwner")
  chatMessages   ChatMessage[]
  notifications  Notification[]
  auditLogs      AuditLog[]
  assignedTasks  WorkspaceTask[] @relation("TaskAssignee")
  createdTasks   WorkspaceTask[] @relation("TaskCreator")
  documentComments DocumentComment[]
  reviewedDocuments GeneratedFile[] @relation("DocumentReviewer")

  @@index([organizationId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Tender {
  id                 String             @id @default(cuid())
  organizationId     String
  ownerId            String?
  tenderNumber       String?
  name               String
  clientName         String
  country            String?
  location           String?
  category           String?
  submissionDeadline DateTime?
  contractDuration   String?
  estimatedValue     Decimal?           @db.Decimal(14, 2)
  currency           String             @default("AED")
  status             TenderStatus       @default(DRAFT)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner              User?              @relation("TenderOwner", fields: [ownerId], references: [id])
  files              TenderFile[]
  documentChunks     TenderDocumentChunk[]
  analysis           TenderAnalysis?
  complianceItems    ComplianceItem[]
  riskItems          RiskItem[]
  assets             Asset[]
  manpowerPlans      ManpowerPlan[]
  costEstimates      CostEstimate[]
  proposals          Proposal[]
  generatedFiles     GeneratedFile[]
  chatConversations  ChatConversation[]
  auditLogs          AuditLog[]
  workspaceTasks     WorkspaceTask[]
  documentComments   DocumentComment[]
  documentVersions   DocumentVersion[]
  activityEvents     ActivityEvent[]

  @@index([organizationId, status])
  @@index([ownerId])
  @@index([submissionDeadline])
}

model TenderFile {
  id             String       @id @default(cuid())
  organizationId String
  tenderId       String?
  purpose        FilePurpose
  displayName    String?
  description    String?
  category       TenderFileCategory @default(OTHER)
  isImportant    Boolean      @default(false)
  version        Int          @default(1)
  fileName       String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  checksum       String?
  extractionStatus ExtractionStatus @default(PENDING)
  extractionError  String?
  extractedText    String?
  extractedAt      DateTime?
  uploadedAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tender         Tender?      @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  chunks         TenderDocumentChunk[]
  workspaceTasks WorkspaceTask[]
  comments       DocumentComment[]

  @@index([organizationId, purpose])
  @@index([tenderId])
  @@index([category])
  @@index([extractionStatus])
}

model TenderDocumentChunk {
  id           String     @id @default(cuid())
  tenderFileId String
  tenderId     String
  chunkIndex   Int
  content      String
  tokenEstimate Int
  pageRef      String?
  metadata     Json?
  createdAt    DateTime   @default(now())
  tenderFile   TenderFile @relation(fields: [tenderFileId], references: [id], onDelete: Cascade)
  tender       Tender     @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderFileId, chunkIndex])
  @@index([tenderId, chunkIndex])
  @@index([tenderFileId])
}

model TenderAnalysis {
  id                  String         @id @default(cuid())
  tenderId            String         @unique
  executiveSummary    String?
  technicalSummary    String?
  commercialSummary   String?
  scopeBreakdown      Json?
  qualificationScore  Int?
  recommendation      Recommendation @default(REVIEW_REQUIRED)
  winProbability      Int?
  sourceMap           Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  tender              Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}

model ComplianceItem {
  id          String           @id @default(cuid())
  tenderId    String
  requirement String
  status      ComplianceStatus @default(MISSING)
  priority    Priority         @default(MEDIUM)
  owner       String?
  action      String?
  source      String?
  pageRef     String?
  confidence  Int?
  tender      Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, status])
}

model RiskItem {
  id          String       @id @default(cuid())
  tenderId    String
  category    RiskCategory
  title       String
  description String?
  score       Int
  mitigation  String?
  source      String?
  pageRef     String?
  tender      Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, category])
}

model Asset {
  id             String  @id @default(cuid())
  tenderId       String
  assetType      String
  name           String
  location       String?
  quantity       Int     @default(1)
  lifecycleNotes String?
  tender         Tender  @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, assetType])
}

model ManpowerPlan {
  id        String          @id @default(cuid())
  tenderId  String
  name      String
  notes     String?
  createdAt DateTime        @default(now())
  tender    Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  lines     ManpowerLine[]

  @@index([tenderId])
}

model ManpowerLine {
  id                 String       @id @default(cuid())
  manpowerPlanId     String
  roleName           String
  quantity           Int
  monthlySalary      Decimal      @db.Decimal(12, 2)
  accommodationCost  Decimal      @default(0) @db.Decimal(12, 2)
  transportCost      Decimal      @default(0) @db.Decimal(12, 2)
  visaCost           Decimal      @default(0) @db.Decimal(12, 2)
  insuranceCost      Decimal      @default(0) @db.Decimal(12, 2)
  uniformCost        Decimal      @default(0) @db.Decimal(12, 2)
  overtimeAllowance  Decimal      @default(0) @db.Decimal(12, 2)
  manpowerPlan       ManpowerPlan @relation(fields: [manpowerPlanId], references: [id], onDelete: Cascade)

  @@index([manpowerPlanId])
}

model CostEstimate {
  id              String         @id @default(cuid())
  tenderId        String
  name            String
  currency        String         @default("AED")
  overheadPercent Decimal        @default(0) @db.Decimal(5, 2)
  profitPercent   Decimal        @default(0) @db.Decimal(5, 2)
  vatPercent      Decimal        @default(5) @db.Decimal(5, 2)
  finalBidPrice   Decimal?       @db.Decimal(14, 2)
  createdAt       DateTime       @default(now())
  tender          Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  lines           EstimateLine[]

  @@index([tenderId])
}

model EstimateLine {
  id             String       @id @default(cuid())
  costEstimateId String
  category       String
  description    String
  quantity       Decimal      @db.Decimal(12, 2)
  unit           String
  unitCost       Decimal      @db.Decimal(12, 2)
  totalCost      Decimal      @db.Decimal(14, 2)
  costEstimate   CostEstimate @relation(fields: [costEstimateId], references: [id], onDelete: Cascade)

  @@index([costEstimateId])
}

model Proposal {
  id             String          @id @default(cuid())
  tenderId       String
  title          String
  status         String          @default("draft")
  sections       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tender         Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  generatedFiles GeneratedFile[]

  @@index([tenderId])
}

model GeneratedFile {
  id         String            @id @default(cuid())
  tenderId   String
  proposalId String?
  kind       GeneratedDocumentKind @default(SUBMISSION_PACKAGE)
  type       GeneratedFileType
  fileName   String
  storageKey String
  title      String?
  content    Json?
  reviewStatus ReviewStatus @default(DRAFT)
  reviewerId String?
  lockedAt   DateTime?
  version    Int              @default(1)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  tender     Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  proposal   Proposal?         @relation(fields: [proposalId], references: [id])
  reviewer   User?             @relation("DocumentReviewer", fields: [reviewerId], references: [id])
  versions   DocumentVersion[]
  comments   DocumentComment[]
  workspaceTasks WorkspaceTask[]

  @@index([tenderId])
  @@index([proposalId])
  @@index([reviewStatus])
  @@index([reviewerId])
}

model DocumentVersion {
  id              String        @id @default(cuid())
  tenderId        String
  generatedFileId String
  version         Int
  title           String
  content         Json?
  changeSummary   String?
  createdById     String?
  createdAt       DateTime      @default(now())
  tender          Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  generatedFile   GeneratedFile @relation(fields: [generatedFileId], references: [id], onDelete: Cascade)

  @@unique([generatedFileId, version])
  @@index([tenderId])
  @@index([createdById])
}

model DocumentComment {
  id              String         @id @default(cuid())
  tenderId        String
  tenderFileId    String?
  generatedFileId String?
  authorId        String?
  content         String
  anchor          Json?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  tender          Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  tenderFile      TenderFile?    @relation(fields: [tenderFileId], references: [id], onDelete: Cascade)
  generatedFile   GeneratedFile? @relation(fields: [generatedFileId], references: [id], onDelete: Cascade)
  author          User?          @relation(fields: [authorId], references: [id])

  @@index([tenderId, createdAt])
  @@index([tenderFileId])
  @@index([generatedFileId])
  @@index([authorId])
}

model WorkspaceTask {
  id              String              @id @default(cuid())
  tenderId        String
  title           String
  description     String?
  assigneeId      String?
  createdById     String?
  dueDate         DateTime?
  priority        Priority            @default(MEDIUM)
  status          WorkspaceTaskStatus @default(TODO)
  relatedFileId   String?
  generatedFileId String?
  relatedAgent    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tender          Tender              @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  assignee        User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy       User?               @relation("TaskCreator", fields: [createdById], references: [id])
  relatedFile     TenderFile?         @relation(fields: [relatedFileId], references: [id], onDelete: SetNull)
  generatedFile   GeneratedFile?      @relation(fields: [generatedFileId], references: [id], onDelete: SetNull)

  @@index([tenderId, status])
  @@index([assigneeId])
  @@index([createdById])
  @@index([relatedFileId])
  @@index([generatedFileId])
  @@index([dueDate])
}

model ActivityEvent {
  id             String       @id @default(cuid())
  organizationId String
  tenderId       String?
  actorId        String?
  message        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  tender         Tender?      @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([tenderId, createdAt])
  @@index([actorId])
}

model IntegrationConnection {
  id             String              @id @default(cuid())
  organizationId String
  provider       IntegrationProvider
  status         IntegrationStatus   @default(NOT_CONNECTED)
  externalAccount String?
  settings       Json?
  lastSyncedAt   DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([organizationId, provider])
  @@index([organizationId, status])
}

model Supplier {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  category       String?
  contactEmail   String?
  contactPhone   String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subcontractors Subcontractor[]

  @@index([organizationId])
}

model Subcontractor {
  id         String   @id @default(cuid())
  supplierId String
  scope      String
  location   String?
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model ChatConversation {
  id        String        @id @default(cuid())
  tenderId  String
  title     String
  createdAt DateTime      @default(now())
  tender    Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([tenderId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  userId         String?
  role           ChatRole
  content        String
  citations      Json?
  confidence     Int?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String
  userId         String?
  tenderId       String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime      @default(now())
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id])
  tender         Tender?       @relation(fields: [tenderId], references: [id])

  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([tenderId])
}

model Subscription {
  id             String       @id @default(cuid())
  organizationId String       @unique
  plan           String
  status         String
  renewsAt       DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
